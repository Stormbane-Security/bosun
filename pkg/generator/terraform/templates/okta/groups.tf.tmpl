# Okta groups and group rules — generated by Bosun
# Creates department-based groups with automatic membership rules.
# AI-suggested structure: one group per department, assigned to relevant apps.

# Department groups — adjust names and descriptions to match your org.
resource "okta_group" "engineering" {
  name        = "Engineering"
  description = "Engineering department — auto-populated via group rule"
}

resource "okta_group" "security" {
  name        = "Security"
  description = "Security team — auto-populated via group rule"
}

resource "okta_group" "devops" {
  name        = "DevOps / Platform"
  description = "DevOps and platform engineering — auto-populated via group rule"
}

resource "okta_group" "it" {
  name        = "IT"
  description = "IT department — auto-populated via group rule"
}

resource "okta_group" "finance" {
  name        = "Finance"
  description = "Finance department — auto-populated via group rule"
}

# Group rules — automatically assign users to groups based on profile attributes.
# These rules evaluate on user creation and profile updates.
resource "okta_group_rule" "engineering_rule" {
  name              = "Auto-assign Engineering"
  status            = "ACTIVE"
  group_assignments = [okta_group.engineering.id]

  expression_type  = "urn:okta:expression:1.0"
  expression_value = "String.stringContains(user.department, \"Engineering\")"
}

resource "okta_group_rule" "security_rule" {
  name              = "Auto-assign Security"
  status            = "ACTIVE"
  group_assignments = [okta_group.security.id]

  expression_type  = "urn:okta:expression:1.0"
  expression_value = "String.stringContains(user.department, \"Security\")"
}

resource "okta_group_rule" "devops_rule" {
  name              = "Auto-assign DevOps"
  status            = "ACTIVE"
  group_assignments = [okta_group.devops.id]

  expression_type  = "urn:okta:expression:1.0"
  expression_value = "String.stringContains(user.department, \"DevOps\") OR String.stringContains(user.department, \"Platform\")"
}

resource "okta_group_rule" "it_rule" {
  name              = "Auto-assign IT"
  status            = "ACTIVE"
  group_assignments = [okta_group.it.id]

  expression_type  = "urn:okta:expression:1.0"
  expression_value = "String.stringContains(user.department, \"IT\") OR String.stringContains(user.department, \"Information Technology\")"
}

resource "okta_group_rule" "finance_rule" {
  name              = "Auto-assign Finance"
  status            = "ACTIVE"
  group_assignments = [okta_group.finance.id]

  expression_type  = "urn:okta:expression:1.0"
  expression_value = "String.stringContains(user.department, \"Finance\")"
}
