# Okta MFA policy — generated by Bosun
# Enforces MFA for all users with modern phishing-resistant factors preferred.

terraform {
  required_providers {
    okta = {
      source  = "okta/okta"
      version = "~> 4.0"
    }
  }
}

resource "okta_policy_mfa" "enforce_mfa" {
  name        = "Bosun - Enforce MFA"
  status      = "ACTIVE"
  description = "Require MFA for all users — generated by Bosun"
  priority    = 1

  is_oie = true

  okta_verify = {
    enroll = "REQUIRED"
  }

  fido_webauthn = {
    enroll = "OPTIONAL"
  }

  okta_email = {
    enroll = "REQUIRED"
  }

  # Disable weaker factors.
  okta_sms = {
    enroll = "NOT_ALLOWED"
  }

  okta_call = {
    enroll = "NOT_ALLOWED"
  }

  okta_question = {
    enroll = "NOT_ALLOWED"
  }

  groups_included = [data.okta_group.everyone.id]
}

resource "okta_policy_rule_mfa" "require_mfa" {
  policy_id = okta_policy_mfa.enforce_mfa.id
  name      = "Require MFA for all"
  status    = "ACTIVE"
  priority  = 1

  enroll = "LOGIN"
}

data "okta_group" "everyone" {
  name = "Everyone"
}
