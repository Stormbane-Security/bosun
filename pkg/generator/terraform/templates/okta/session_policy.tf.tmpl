# Okta session policy — generated by Bosun
# Sets reasonable session timeouts to reduce session hijacking risk.

resource "okta_policy_signon" "session_limits" {
  name        = "Bosun - Session Limits"
  status      = "ACTIVE"
  description = "Enforce session idle and lifetime limits — generated by Bosun"
  priority    = 1

  groups_included = [data.okta_group.everyone.id]
}

resource "okta_policy_rule_signon" "session_limits" {
  policy_id = okta_policy_signon.session_limits.id
  name      = "Session timeout rule"
  status    = "ACTIVE"
  priority  = 1

  access            = "ALLOW"
  mfa_required      = true
  mfa_prompt        = "SESSION"
  mfa_lifetime      = 720  # Re-prompt MFA every 12 hours

  session_idle      = 60   # Idle timeout: 1 hour
  session_lifetime  = 720  # Max session: 12 hours
  session_persistent = false
}

data "okta_group" "everyone" {
  name = "Everyone"
}
