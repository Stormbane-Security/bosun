# EC2 security group hardening — generated by Bosun
# Removes 0.0.0.0/0 ingress and restricts to known CIDR blocks.

resource "aws_security_group" "hardened" {
  name        = "bosun-hardened-sg"
  description = "Security group with restricted ingress — generated by Bosun"
  vpc_id      = var.vpc_id

  # Allow HTTPS from known CIDR blocks only.
  ingress {
    description = "HTTPS"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = var.allowed_cidrs
  }

  # Allow all outbound traffic.
  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    ManagedBy = "bosun"
  }
}

variable "vpc_id" {
  description = "VPC ID for the security group"
  type        = string
}

variable "allowed_cidrs" {
  description = "CIDR blocks allowed to access the instance"
  type        = list(string)
  default     = []
}
