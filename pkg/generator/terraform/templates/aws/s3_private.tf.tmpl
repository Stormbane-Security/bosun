# S3 bucket security hardening — generated by Bosun
# Uses the official terraform-aws-modules/s3-bucket module for best practices.
# Enables: public access block, KMS encryption, versioning, access logging.

module "s3_bucket" {
  source  = "terraform-aws-modules/s3-bucket/aws"
  version = "~> 4.0"

  bucket = "{{.bucket_name}}"

  # Block all public access.
  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true

  # Enable versioning.
  versioning = {
    enabled = true
  }

  # Server-side encryption with AWS KMS.
  server_side_encryption_configuration = {
    rule = {
      apply_server_side_encryption_by_default = {
        sse_algorithm = "aws:kms"
      }
      bucket_key_enabled = true
    }
  }

  # Access logging.
  logging = {
    target_bucket = "{{.bucket_name}}"
    target_prefix = "access-logs/"
  }

  # Object ownership — bucket owner enforced (disables ACLs).
  control_object_ownership = true
  object_ownership         = "BucketOwnerEnforced"

  tags = {
    ManagedBy = "bosun"
  }
}
