# Cloud SQL private access — generated by Bosun
# Uses the official terraform-google-modules/sql-db module for security hardening.
# Removes public access, enforces SSL, enables backups and audit logging.

module "cloudsql" {
  source  = "terraform-google-modules/sql-db/google//modules/postgresql"
  version = "~> 23.0"

  project_id = var.project_id
  name       = var.instance_name
  region     = var.region

  database_version = var.database_version
  tier             = var.tier

  # Private IP only — no public access.
  ip_configuration = {
    ipv4_enabled    = false
    private_network = var.vpc_network
    require_ssl     = true
    # No authorized_networks — access via private IP only.
    authorized_networks = []
  }

  # Backup configuration.
  backup_configuration = {
    enabled                        = true
    point_in_time_recovery_enabled = true
    start_time                     = "03:00"
    retained_backups               = 30
    retention_unit                 = "COUNT"
  }

  # Audit and security database flags.
  database_flags = [
    { name = "log_checkpoints", value = "on" },
    { name = "log_connections", value = "on" },
    { name = "log_disconnections", value = "on" },
    { name = "log_statement", value = "ddl" },
  ]

  deletion_protection = true

  user_labels = {
    managed-by = "bosun"
  }
}

variable "instance_name" {
  description = "Cloud SQL instance name"
  type        = string
}

variable "database_version" {
  description = "Database version (e.g., POSTGRES_15)"
  type        = string
  default     = "POSTGRES_15"
}

variable "region" {
  description = "GCP region"
  type        = string
}

variable "project_id" {
  description = "GCP project ID"
  type        = string
}

variable "tier" {
  description = "Machine type (e.g., db-f1-micro)"
  type        = string
  default     = "db-f1-micro"
}

variable "vpc_network" {
  description = "VPC network self_link for private IP"
  type        = string
}
