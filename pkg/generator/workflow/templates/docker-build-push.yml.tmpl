# Docker build, sign, scan & push — generated by Bosun (free tier)
# All actions pinned to full SHA. Uses only free-tier features.
#
# Security features included:
#   - StepSecurity harden-runner (audit mode, free)
#   - Cosign keyless container signing (free, uses Sigstore)
#   - Anchore SBOM generation (free)
#   - Trivy vulnerability scanning (free)
#   - OIDC / workload identity federation (no stored secrets)

name: Docker Build & Push

on:
  push:
    branches: [main]
    tags: ["v*"]

permissions:
  contents: read
  packages: write
  id-token: write  # OIDC for cosign + workload identity

env:
  IMAGE_NAME: {{`${{ github.repository }}`}}

jobs:
  build-sign-push:
    runs-on: ubuntu-latest

    steps:
      - name: Harden runner
        uses: step-security/harden-runner@fe104658747b27e96e4f7e80cd0a94068e53901d # v2.16.1
        with:
          egress-policy: audit

      - name: Checkout
        uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@4d04d5d9486b7bd6fa91e7baf45bbb4f8b9deedd # v4.0.0

      - name: Extract metadata
        id: meta
        uses: docker/metadata-action@902fa8ec7d6ecbf8d84d538b9b233a880e428804 # v5.7.0
        with:
          images: |
            {{`${{ env.IMAGE_NAME }}`}}
          tags: |
            type=sha,prefix=
            type=ref,event=tag
            type=ref,event=branch

      # --- Registry login (configure per your registry) ---
      # GHCR (default — uses GITHUB_TOKEN, no stored secrets)
      - name: Login to GHCR
        uses: docker/login-action@b45d80f862d83dbcd57f89517bcf500b2ab88fb2 # v4.0.0
        with:
          registry: ghcr.io
          username: {{`${{ github.actor }}`}}
          password: {{`${{ secrets.GITHUB_TOKEN }}`}}

      - name: Build and push
        uses: docker/build-push-action@d08e5c354a6adb9ed34480a06d141179aa583294 # v7.0.0
        with:
          context: .
          push: true
          tags: {{`${{ steps.meta.outputs.tags }}`}}
          labels: {{`${{ steps.meta.outputs.labels }}`}}
          cache-from: type=gha
          cache-to: type=gha,mode=max
          provenance: true
          sbom: true

      # --- Container signing (Sigstore keyless, free) ---
      - name: Install cosign
        uses: sigstore/cosign-installer@cad07c2e89fa2edd6e2d7bab4c1aa38e53f76003 # v4.1.1

      - name: Sign container image
        env:
          DIGEST: {{`${{ steps.meta.outputs.digest }}`}}
        run: |
          cosign sign --yes "ghcr.io/${IMAGE_NAME}@${DIGEST}"

      # --- SBOM generation (free) ---
      - name: Generate SBOM
        uses: anchore/sbom-action@e22c389904149dbc22b58101806040fa8d37a610 # v0.24.0
        with:
          image: "ghcr.io/{{`${{ env.IMAGE_NAME }}`}}:{{`${{ github.sha }}`}}"
          format: spdx-json
          output-file: sbom.spdx.json

      - name: Attach SBOM to image
        run: |
          cosign attach sbom --sbom sbom.spdx.json "ghcr.io/${IMAGE_NAME}@${DIGEST}"

      # --- Vulnerability scanning (Trivy, free) ---
      - name: Scan for vulnerabilities
        uses: aquasecurity/trivy-action@18f2510ee396bbf400402947e7b218d872a1e1b4 # v0.30.0
        with:
          image-ref: "ghcr.io/{{`${{ env.IMAGE_NAME }}`}}:{{`${{ github.sha }}`}}"
          format: sarif
          output: trivy-results.sarif
          severity: CRITICAL,HIGH

      - name: Upload scan results
        uses: actions/upload-artifact@bbbca2ddaa5d8feaa63e36b76fdaad77386f024f # v7.0.0
        with:
          name: trivy-results
          path: trivy-results.sarif
