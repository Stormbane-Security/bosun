# GCS bucket security hardening — generated by Bosun
# Enforces uniform bucket-level access, encryption, and versioning.

resource "google_storage_bucket" "{{.bucket_name}}" {
  name          = "{{.bucket_name}}"
  location      = var.region
  force_destroy = false

  uniform_bucket_level_access = true

  versioning {
    enabled = true
  }

  encryption {
    default_kms_key_name = var.kms_key_name
  }

  logging {
    log_bucket        = var.log_bucket
    log_object_prefix = "{{.bucket_name}}/"
  }

  labels = {
    managed-by = "bosun"
  }
}

# Deny allUsers and allAuthenticatedUsers.
resource "google_storage_bucket_iam_member" "deny_public" {
  bucket = google_storage_bucket.{{.bucket_name}}.name
  role   = "roles/storage.objectViewer"
  member = "projectViewer:${var.project_id}"
}

variable "region" {
  description = "GCS bucket region"
  type        = string
  default     = "US"
}

variable "kms_key_name" {
  description = "Cloud KMS key for bucket encryption"
  type        = string
  default     = ""
}

variable "log_bucket" {
  description = "Bucket for access logs"
  type        = string
  default     = ""
}

variable "project_id" {
  description = "GCP project ID"
  type        = string
}
