# GKE cluster hardening — generated by Bosun
# Uses the official terraform-google-modules/kubernetes-engine module
# with the "safer-cluster" submodule for security best practices.

module "gke" {
  source  = "terraform-google-modules/kubernetes-engine/google//modules/safer-cluster"
  version = "~> 44.0"

  project_id = var.project_id
  name       = var.cluster_name
  region     = var.region

  # Private cluster — no public endpoint.
  enable_private_endpoint = true
  enable_private_nodes    = true
  master_ipv4_cidr_block  = var.master_cidr

  # Network configuration.
  network    = var.network
  subnetwork = var.subnetwork

  # Workload Identity (replaces node service account keys).
  identity_namespace = "${var.project_id}.svc.id.goog"

  # Release channel for automatic security patches.
  release_channel = "REGULAR"

  # Binary Authorization — verify container image signatures.
  enable_binary_authorization = true

  # Network policy enforcement.
  network_policy = true

  # Shielded nodes.
  enable_shielded_nodes = true

  # Node pool configuration.
  node_pools = [
    {
      name               = "default-pool"
      machine_type       = var.machine_type
      min_count          = var.min_nodes
      max_count          = var.max_nodes
      disk_size_gb       = 100
      disk_type          = "pd-standard"
      auto_repair        = true
      auto_upgrade       = true
      service_account    = var.node_service_account
      initial_node_count = var.min_nodes
    },
  ]

  node_pools_oauth_scopes = {
    all = ["https://www.googleapis.com/auth/cloud-platform"]
  }

  node_pools_metadata = {
    all = {
      disable-legacy-endpoints = "true"
    }
  }

  node_pools_labels = {
    all = {
      managed-by = "bosun"
    }
  }
}

variable "cluster_name" {
  description = "GKE cluster name"
  type        = string
}

variable "region" {
  description = "GCP region"
  type        = string
}

variable "project_id" {
  description = "GCP project ID"
  type        = string
}

variable "network" {
  description = "VPC network name"
  type        = string
}

variable "subnetwork" {
  description = "VPC subnetwork name"
  type        = string
}

variable "master_cidr" {
  description = "CIDR block for the GKE master"
  type        = string
  default     = "172.16.0.0/28"
}

variable "node_service_account" {
  description = "Service account for GKE nodes"
  type        = string
}

variable "machine_type" {
  description = "Node pool machine type"
  type        = string
  default     = "e2-medium"
}

variable "min_nodes" {
  description = "Minimum nodes per zone"
  type        = number
  default     = 1
}

variable "max_nodes" {
  description = "Maximum nodes per zone"
  type        = number
  default     = 3
}
