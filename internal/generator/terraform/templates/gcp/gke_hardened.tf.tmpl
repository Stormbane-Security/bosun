# GKE cluster hardening — generated by Bosun
# Disables legacy auth, enables shielded nodes, workload identity,
# network policy, binary authorization, and private cluster mode.

resource "google_container_cluster" "hardened" {
  name     = var.cluster_name
  location = var.region
  project  = var.project_id

  # Disable legacy ABAC and enable RBAC only.
  enable_legacy_abac = false

  # Private cluster — no public endpoint.
  private_cluster_config {
    enable_private_nodes    = true
    enable_private_endpoint = true
    master_ipv4_cidr_block  = var.master_cidr
  }

  # Workload Identity (replaces node service account keys).
  workload_identity_config {
    workload_pool = "${var.project_id}.svc.id.goog"
  }

  # Shielded nodes — verifies node integrity.
  node_config {
    shielded_instance_config {
      enable_secure_boot          = true
      enable_integrity_monitoring = true
    }

    workload_metadata_config {
      mode = "GKE_METADATA"
    }

    service_account = var.node_service_account
    oauth_scopes    = ["https://www.googleapis.com/auth/cloud-platform"]
  }

  # Network policy enforcement.
  network_policy {
    enabled  = true
    provider = "CALICO"
  }

  addons_config {
    network_policy_config {
      disabled = false
    }
  }

  # Binary Authorization — verify container image signatures.
  binary_authorization {
    evaluation_mode = "PROJECT_SINGLETON_POLICY"
  }

  # Release channel for automatic security patches.
  release_channel {
    channel = "REGULAR"
  }

  resource_labels = {
    managed-by = "bosun"
  }
}

variable "cluster_name" {
  description = "GKE cluster name"
  type        = string
}

variable "region" {
  description = "GCP region"
  type        = string
}

variable "project_id" {
  description = "GCP project ID"
  type        = string
}

variable "master_cidr" {
  description = "CIDR block for the GKE master"
  type        = string
  default     = "172.16.0.0/28"
}

variable "node_service_account" {
  description = "Service account for GKE nodes"
  type        = string
}
