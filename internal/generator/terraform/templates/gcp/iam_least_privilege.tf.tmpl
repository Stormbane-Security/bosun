# IAM least privilege — generated by Bosun
# Replaces primitive roles (Owner/Editor/Viewer) with predefined roles.
# Review and adjust the specific roles for your use case.

# Remove primitive role bindings and replace with least-privilege.
# This template provides the structure — you must specify the correct
# predefined role for each service account's actual needs.

resource "google_project_iam_member" "least_privilege" {
  project = var.project_id
  role    = var.replacement_role
  member  = var.member
}

variable "project_id" {
  description = "GCP project ID"
  type        = string
}

variable "member" {
  description = "IAM member (e.g., serviceAccount:sa@project.iam.gserviceaccount.com)"
  type        = string
}

variable "replacement_role" {
  description = "Predefined role to replace the primitive role (e.g., roles/storage.admin)"
  type        = string
}
