# S3 bucket security hardening — generated by Bosun
# Enables public access block, encryption, versioning, and access logging.

resource "aws_s3_bucket" "{{.bucket_name}}" {
  bucket = "{{.bucket_name}}"

  tags = {
    ManagedBy = "bosun"
  }
}

resource "aws_s3_bucket_public_access_block" "{{.bucket_name}}" {
  bucket = aws_s3_bucket.{{.bucket_name}}.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_s3_bucket_versioning" "{{.bucket_name}}" {
  bucket = aws_s3_bucket.{{.bucket_name}}.id

  versioning_configuration {
    status = "Enabled"
  }
}

resource "aws_s3_bucket_server_side_encryption_configuration" "{{.bucket_name}}" {
  bucket = aws_s3_bucket.{{.bucket_name}}.id

  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "aws:kms"
    }
    bucket_key_enabled = true
  }
}

resource "aws_s3_bucket_logging" "{{.bucket_name}}" {
  bucket = aws_s3_bucket.{{.bucket_name}}.id

  target_bucket = aws_s3_bucket.{{.bucket_name}}.id
  target_prefix = "access-logs/"
}
