# Okta password policy — generated by Bosun
# Enforces strong passwords aligned with NIST 800-63B recommendations.

resource "okta_policy_password" "strong_passwords" {
  name        = "Bosun - Strong Password Policy"
  status      = "ACTIVE"
  description = "NIST 800-63B aligned password policy — generated by Bosun"
  priority    = 1

  # Minimum 12 characters with complexity requirements.
  password_min_length   = 14
  password_min_lowercase = 1
  password_min_uppercase = 1
  password_min_number    = 1
  password_min_symbol    = 1

  # Prevent reuse of last 10 passwords.
  password_history_count = 10

  # Account lockout after 5 failed attempts.
  password_max_lockout_attempts        = 5
  password_auto_unlock_minutes         = 15
  password_show_lockout_failures       = true

  # Exclude common patterns.
  password_exclude_username   = true
  password_exclude_first_name = true
  password_exclude_last_name  = true

  # Recovery settings.
  recovery_email_token         = 60
  email_recovery               = "ACTIVE"
  sms_recovery                 = "INACTIVE"
  call_recovery                = "INACTIVE"
  question_recovery            = "INACTIVE"

  groups_included = [data.okta_group.everyone.id]
}

resource "okta_policy_rule_password" "default" {
  policy_id = okta_policy_password.strong_passwords.id
  name      = "Default"
  status    = "ACTIVE"
  priority  = 1
}

data "okta_group" "everyone" {
  name = "Everyone"
}
