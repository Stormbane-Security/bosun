# Beacon security scan — generated by Bosun (free tier)
# Runs Beacon in surface mode on PRs to detect security regressions.
# All actions pinned to full SHA.

name: Beacon Scan

on:
  pull_request:
    branches: [main]
  schedule:
    - cron: "0 6 * * 1"  # Weekly Monday 06:00 UTC

permissions:
  contents: read
  security-events: write  # Upload SARIF if GHAS is available

jobs:
  scan:
    runs-on: ubuntu-latest

    steps:
      - name: Harden runner
        uses: step-security/harden-runner@fe104658747b27e96e4f7e80cd0a94068e53901d # v2.16.1
        with:
          egress-policy: audit

      - name: Checkout
        uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2

      - name: Setup Go
        uses: actions/setup-go@4a3601121dd01d1626a1e23e37211e3254c1c06c # v6.4.0
        with:
          go-version-file: go.mod
          cache: true

      - name: Install Beacon
        run: go install github.com/stormbane/beacon/cmd/beacon@latest

      - name: Run surface scan
        run: |
          beacon scan --targets targets.txt --format json --output beacon-results.json
        continue-on-error: true

      - name: Upload results
        uses: actions/upload-artifact@bbbca2ddaa5d8feaa63e36b76fdaad77386f024f # v7.0.0
        with:
          name: beacon-results
          path: beacon-results.json
