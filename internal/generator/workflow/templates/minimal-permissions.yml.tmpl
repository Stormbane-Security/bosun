# Minimal-permissions CI workflow — generated by Bosun (free tier)
# Sets the most restrictive GITHUB_TOKEN permissions possible.
# All actions pinned to full commit SHAs.

name: CI

on:
  pull_request:
    branches: [main]
  push:
    branches: [main]

# Top-level: restrict to read-only by default.
permissions:
  contents: read

jobs:
  lint-and-test:
    runs-on: ubuntu-latest

    # Job-level: no additional permissions needed.
    permissions:
      contents: read

    steps:
      - name: Harden runner
        uses: step-security/harden-runner@fe104658747b27e96e4f7e80cd0a94068e53901d # v2.16.1
        with:
          egress-policy: audit

      - name: Checkout
        uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2

      - name: Build
        run: echo "Add your build steps here"

      - name: Test
        run: echo "Add your test steps here"
